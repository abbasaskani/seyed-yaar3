{
  "notes": "Lean runtime config. All depth-aware ocean datasets resolve the closest depth to the sea surface (0m). Wind defaults to a cheap surface proxy or local ERA5 if present.",
  "cmems": {
    "sst": {
      "product": "GLOBAL_ANALYSISFORECAST_PHY_001_024",
      "dataset_id": "cmems_mod_glo_phy-thetao_anfc_0.083deg_PT6H-i",
      "variable": "thetao",
      "depth_target_m": 0.0,
      "units": "degrees_C"
    },
    "currents": {
      "product": "GLOBAL_ANALYSISFORECAST_PHY_001_024",
      "dataset_id": "cmems_mod_glo_phy-cur_anfc_0.083deg_PT6H-i",
      "variables": ["uo", "vo"],
      "depth_target_m": 0.0,
      "units": "m s-1"
    },
    "ssh": {
      "product": "GLOBAL_ANALYSISFORECAST_PHY_001_024",
      "dataset_id": "cmems_mod_glo_phy_anfc_0.083deg_PT1H-m",
      "variable": "zos",
      "units": "m",
      "notes": "No depth axis."
    },
    "waves": {
      "product": "GLOBAL_ANALYSISFORECAST_WAV_001_027",
      "dataset_id": "cmems_mod_glo_wav_anfc_0.083deg_PT3H-i",
      "variable": "VHM0",
      "units": "m",
      "notes": "No depth axis."
    },
    "chl": {
      "product": "GLOBAL_ANALYSISFORECAST_BGC_001_028",
      "dataset_id": "cmems_mod_glo_bgc-pft_anfc_0.25deg_P1D-m",
      "variable": "chl",
      "depth_target_m": 0.0,
      "units": "mg m-3"
    },
    "mld": {
      "product": "GLOBAL_ANALYSISFORECAST_PHY_001_024",
      "dataset_id": "cmems_mod_glo_phy_anfc_0.083deg_P1D-m",
      "variable": "mlotst",
      "units": "m",
      "notes": "Surface diagnostic; no depth slice."
    },
    "o2": {
      "product": "GLOBAL_ANALYSISFORECAST_BGC_001_028",
      "dataset_id": "cmems_mod_glo_bgc-bio_anfc_0.25deg_P1D-m",
      "variable": "o2",
      "depth_target_m": 0.0,
      "units": "mmol m-3"
    },
    "sss": {
      "product": "GLOBAL_ANALYSISFORECAST_PHY_001_024",
      "dataset_id": "cmems_mod_glo_phy-so_anfc_0.083deg_PT6H-i",
      "variable": "so",
      "depth_target_m": 0.0,
      "units": "psu"
    },
    "npp": {
      "product": "GLOBAL_ANALYSISFORECAST_BGC_001_028",
      "dataset_id": "cmems_mod_glo_bgc-bio_anfc_0.25deg_P1D-m",
      "variable": "nppv",
      "depth_target_m": 0.0,
      "units": "mg C m-3 d-1",
      "notes": "Optional. Disabled by default in lean mode."
    },
    "wind": {
      "mode": "local_era5_or_proxy",
      "local_template": "backend/data/wind/era5_{date}.nc",
      "variables": ["u10", "v10"],
      "notes": "Runtime first tries local ERA5 u10/v10. If missing, it falls back to a cheap wave/current proxy to avoid extra network fetches."
    }
  }
}
